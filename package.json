{
  "name": "xml-converter-to-db",
  "private": true,
  "packageManager": "npm@10.2.3",
  "engines": {
    "node": ">=20.19.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "npm run start -w catalog-api",
    "lint": "turbo lint",
    "db:generate": "npm run db:generate -w @repo/db",
    "db:push": "npm run db:push -w @repo/db",
    "db:studio": "npm run db:studio -w @repo/db"
  },
  "devDependencies": {
    "turbo": "^2.4.4"
  }
}
