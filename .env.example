# Спільно для catalog-api та prisma (packages/db)
DATABASE_URL=postgresql://catalog:catalog@127.0.0.1:5436/catalog

# Next.js store — URL HTTP API каталогу
CATALOG_API_URL=http://127.0.0.1:4001

# Vite admin (apps/admin): скопіюйте у apps/admin/.env.local або задайте той самий URL
# VITE_CATALOG_API_URL=http://127.0.0.1:4001

# Мутації каталогу: POST/PATCH /api/admin/* (заголовок X-API-Key)
ADMIN_API_KEY=1234567890

# Замовлення: catalog-api POST /api/orders → Telegram Bot API
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# За потреби
# CATALOG_API_PORT=4001
# У Easypanel / Docker часто є тільки PORT — він має пріоритет над CATALOG_API_PORT.
# Локально можна лишити CATALOG_API_HOST=127.0.0.1; у прод-контейнері краще 0.0.0.0 (дефолт).
# CATALOG_API_HOST=127.0.0.1
