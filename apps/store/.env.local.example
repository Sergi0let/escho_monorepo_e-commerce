# URL catalog-api (apps/catalog-api). Скопіюйте також DATABASE_URL у корінь .env для Prisma.
# У бандл для браузера те саме підставляє next.config.ts як NEXT_PUBLIC_CATALOG_API_URL (кошик з картки).
CATALOG_API_URL=http://127.0.0.1:4001
# За потреби окремий публічний URL:
# NEXT_PUBLIC_CATALOG_API_URL=https://api.example.com

# Змінні Telegram задати в корені репозиторію (.env) — їх читає catalog-api для POST /api/orders.
# Або в цьому файлі; catalog-api підвантажує apps/store/.env.local при старті.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=   # кілька id через кому
