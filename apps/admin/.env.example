# URL Express catalog-api (той самий, що для вітрини). Порт за замовчуванням 4001.
VITE_CATALOG_API_URL=http://127.0.0.1:4001

# Для маршрутів /api/admin/* — збіг з ADMIN_API_KEY у catalog-api.
# Увага: у Vite це потрапляє в JS-бандл; для публічного продакшену краще проксі на бекенді.
VITE_CATALOG_ADMIN_API_KEY=1234567890
