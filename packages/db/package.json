{
  "name": "@repo/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "cd ../.. && prisma generate --schema=packages/db/prisma/schema.prisma && cd packages/db && tsc",
    "db:generate": "cd ../.. && prisma generate --schema=packages/db/prisma/schema.prisma",
    "db:push": "cd ../.. && prisma db push --schema=packages/db/prisma/schema.prisma",
    "db:studio": "cd ../.. && prisma studio --schema=packages/db/prisma/schema.prisma",
    "lint": "node -e \"process.exit(0)\""
  },
  "dependencies": {
    "@prisma/client": "^6.19.1"
  },
  "devDependencies": {
    "prisma": "6.19.1",
    "typescript": "^5.7.2"
  }
}
