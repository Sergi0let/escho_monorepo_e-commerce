generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  male
  female
  unisex
  unknown
}

model Category {
  id        BigInt     @id
  parentId  BigInt?    @map("parent_id")
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Category[] @relation("CategoryTree")
  name      String
  updatedAt DateTime   @map("updated_at") @db.Timestamptz(6)
  products  Product[]

  @@map("categories")
}

model Product {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  groupKey     String         @unique @map("group_key")
  title        String?
  description  String?
  categoryId   BigInt?        @map("category_id")
  category     Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  gender       Gender         @default(unknown)
  brand        String?
  fabric       String?
  country      String?
  productKind  String?        @map("product_kind")
  feedShopName String?        @map("feed_shop_name")
  updatedAt    DateTime       @map("updated_at") @db.Timestamptz(6)
  colors       ProductColor[]
  skus         Sku[]

  @@map("products")
}

model ProductColor {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  colorName String   @map("color_name")
  sortOrder Int      @default(0) @map("sort_order")
  imageUrls String[] @default([]) @map("image_urls")
  skus      Sku[]

  @@unique([productId, colorName])
  @@map("product_colors")
}

model Sku {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  barcode         String       @unique
  productId       String       @map("product_id") @db.Uuid
  product         Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  productColorId  String       @map("product_color_id") @db.Uuid
  productColor    ProductColor @relation(fields: [productColorId], references: [id], onDelete: Cascade)
  externalOfferId String?      @map("external_offer_id")
  sizeLabel       String?      @map("size_label")
  price           Decimal      @db.Decimal(12, 2)
  oldPrice        Decimal      @map("old_price") @db.Decimal(12, 2)
  currency        String       @default("UAH")
  stockQuantity   Int?         @map("stock_quantity")
  available       Boolean      @default(true)
  chestCm         Int?         @map("chest_cm")
  waistCm         Int?         @map("waist_cm")
  hipsCm          Int?         @map("hips_cm")

  @@map("skus")
}
